<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Overlap Smooth Scroll</title>
  <style>
    html, body {
      margin: 0; 
      padding: 0;
      height: 100%;
      font-family: sans-serif;
    }
    /* Un reset rapide */
    * {
      box-sizing: border-box;
    }

    /* ===== HEADER SIMULÉ (ex. 100vh) ===== */
    header {
      height: 100vh;
      background: #aaa;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: #fff;
    }

    /* ===== CONTENEUR PRINCIPAL =====
       Pour que l'on puisse scroller suffisamment, on lui donne 200vh 
       (car on veut 2 "écrans" superposés).
    */
    .scroll-container {
      position: relative;
      height: 200vh; 
      background: #eee; 
      margin: 0; 
      padding: 0;
    }

    /* ============================
       WORK1 et WORK2 en "sticky"
       ============================ */
    .panel {
      position: sticky;
      top: 0;
      width: 100%;
      height: 100vh;

      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      color: #fff;
    }

    #work1 {
      background: #2c3e50; /* bleu foncé */
      z-index: 1;          /* en dessous */
    }

    #work2 {
      background: #c0392b; /* rouge */
      z-index: 2;          /* au-dessus */
      /* Au départ : Work2 est caché en bas => translateY(100%) */
      transform: translateY(100%);
      /* On veut une transition plus "directe" ? 
         Ici on n'ajoute PAS de transition, car on veut que 
         le mouvement soit piloté en temps réel par le scroll.
         Si vous mettez transition, ça "adoucirait" mais risquerait 
         de créer un effet de retard. 
      */
    }

    /* Juste pour avoir un "après" qui continue le scroll */
    .after {
      height: 100vh; 
      background: #999; 
      display: flex; 
      align-items: center; 
      justify-content: center;
      font-size: 2rem; 
      color: #fff;
    }
  </style>
</head>
<body>

  <header>
    <div>HEADER (100vh)</div>
  </header>

  <div class="scroll-container" id="scrollContainer">
    <!-- SECTION Work1 (dessous) -->
    <section id="work1" class="panel">
      <h1>WORK 1</h1>
    </section>
    <!-- SECTION Work2 (dessus) -->
    <section id="work2" class="panel">
      <h1>WORK 2</h1>
    </section>
  </div>

  <div class="after">
    <div>Contenu APRÈS (1 écran)</div>
  </div>

  <script>
    // 1) Sélectionner nos sections
    const work2 = document.getElementById("work2");
    const container = document.getElementById("scrollContainer");

    // 2) Calcule la zone "utile" de défilement 
    //    pour animer l'apparition progressive de Work2.
    //    - Début = le haut de .scroll-container 
    //    - Fin = le bas de .scroll-container 
    //      (ou un peu moins, selon l'effet souhaité)

    // On attend le "DOMContentLoaded" ou "load" pour que
    // offsetTop et offsetHeight soient corrects (si images, etc.)
    window.addEventListener('DOMContentLoaded', () => {
      setupScrolling();
    });

    function setupScrolling() {
      // position absolue du conteneur par rapport au document
      const containerStart = container.offsetTop;
      // hauteur du conteneur
      const containerHeight = container.offsetHeight;

      // calcul de la zone de défilement 
      // (on veut que l'animation se fasse sur la hauteur de 1 écran 
      //  dans ce cas. On pourrait le faire sur tout containerHeight 
      //  si on veut. À adapter.)
      const windowH = window.innerHeight;
      // On peut décider que l'animation se fasse 
      // entre containerStart et containerStart + windowH
      // de sorte que sur la 2e moitié, Work2 soit entièrement affiché.

      const startAnim = containerStart;          // début animation
      const endAnim   = containerStart + windowH; // fin animation

      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;

        // Calculer la progression entre 0 et 1
        let progress = (scrollY - startAnim) / (endAnim - startAnim);

        // Clamper entre 0 et 1 pour ne pas dépasser
        if (progress < 0) progress = 0;
        if (progress > 1) progress = 1;

        // On veut qu'à progress=0 => translateY(100%) (invisible en bas)
        // et à progress=1 => translateY(0%) (complètement visible).
        const translateValue = 100 - (100 * progress);

        // Appliquer le transform
        work2.style.transform = `translateY(${translateValue}%)`;
      });
    }
  </script>
</body>
</html>
